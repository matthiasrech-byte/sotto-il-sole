---
interface Props {
  lang?: 'de' | 'it';
}

const { lang = 'de' } = Astro.props;

const isItalian = lang === 'it';

const navItems = isItalian
  ? [
      { label: 'Marchi', href: '/it/#marken' },
      { label: 'Chi siamo', href: '/it/#ueber-uns' },
      { label: 'Contatto', href: '/it/#kontakt' },
    ]
  : [
      { label: 'Marken', href: '/#marken' },
      { label: 'Über uns', href: '/#ueber-uns' },
      { label: 'Kontakt', href: '/#kontakt' },
    ];

const homeHref = isItalian ? '/it/' : '/';
const ariaLabel = isItalian ? 'SOTTO IL SOLE pagina iniziale' : 'SOTTO IL SOLE Startseite';
---

<header class="site-header">
  <a class="site-header__logo" href={homeHref} aria-label={ariaLabel}>
    <span>SOTTO IL SOLE</span>
    <img
      src="/logo-symbol.png"
      alt=""
      class="site-header__symbol"
      aria-hidden="true"
    />
  </a>

  <div class="site-header__right">
    <nav class="site-header__nav" aria-label={isItalian ? 'Navigazione principale' : 'Hauptnavigation'}>
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="site-header__language" aria-label="Sprachauswahl">
      <a href="/" class:list={[!isItalian && 'is-active']}>DE</a>
      <span>|</span>
      <a href="/it/" class:list={[isItalian && 'is-active']}>IT</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(0, 53, 20, 0.1);
    background: rgba(222, 218, 213, 0.86);
    backdrop-filter: blur(18px);
  }

  .site-header__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    color: inherit;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-decoration: none;
  }

  .site-header__symbol {
    display: block;
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .site-header__right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .site-header__nav {
    display: flex;
    gap: 1rem;
    font-size: 0.92rem;
    font-weight: 800;
  }

  .site-header__nav a {
    color: inherit;
    text-decoration: none;
  }

  .site-header__nav a:hover {
    color: var(--color-orange);
  }

  .site-header__language {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
  }

  .site-header__language a {
    color: rgba(0, 53, 20, 0.55);
    text-decoration: none;
  }

  .site-header__language a:hover,
  .site-header__language a.is-active {
    color: var(--color-green-dark);
  }

  .site-header__language span {
    color: rgba(0, 53, 20, 0.35);
  }

  @media (max-width: 680px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.7rem;
    }

    .site-header__right {
      width: 100%;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .site-header__nav {
      gap: 0.7rem;
      font-size: 0.86rem;
    }

    .site-header__language {
      flex-shrink: 0;
    }
  }
</style>
