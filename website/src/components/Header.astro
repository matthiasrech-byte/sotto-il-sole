---
const navItems = [
  { label: 'Marken', href: '#marken' },
  { label: 'Über uns', href: '#ueber-uns' },
  { label: 'Kontakt', href: '#kontakt' },
];
---

<header class="site-header">
  <a class="site-header__logo" href="#top" aria-label="SOTTO IL SOLE Startseite">
    <span>SOTTO IL SOLE</span>
    <img
      src="/logo-symbol.png"
      alt=""
      class="site-header__symbol"
      aria-hidden="true"
    />
  </a>

  <nav class="site-header__nav" aria-label="Hauptnavigation">
    {navItems.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(0, 53, 20, 0.1);
    background: rgba(222, 218, 213, 0.86);
    backdrop-filter: blur(18px);
  }

  .site-header__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    color: inherit;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-decoration: none;
  }

  .site-header__symbol {
    display: block;
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .site-header__nav {
    display: flex;
    gap: 1rem;
    font-size: 0.92rem;
    font-weight: 800;
  }

  .site-header__nav a {
    color: inherit;
    text-decoration: none;
  }

  .site-header__nav a:hover {
    color: var(--color-orange);
  }

  @media (max-width: 680px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.7rem;
    }

    .site-header__nav {
      width: 100%;
      justify-content: space-between;
      gap: 0.5rem;
    }
  }
</style>
