---
import RotatingLogo from './RotatingLogo.astro';

interface Props {
  lang?: 'de' | 'it';
}

const { lang = 'de' } = Astro.props;

const isItalian = lang === 'it';

const copy = isItalian
  ? {
      legalLabel: 'Informazioni legali',
      imprint: 'Note legali',
      privacy: 'Privacy',
      imprintHref: '/it/impressum',
      privacyHref: '/it/datenschutz',
    }
  : {
      legalLabel: 'Rechtliches',
      imprint: 'Impressum',
      privacy: 'Datenschutz',
      imprintHref: '/impressum',
      privacyHref: '/datenschutz',
    };
---

<footer class="footer">
  <div class="container footer__inner">
    <p>SOTTO IL SOLE</p>

    <RotatingLogo />

    <nav aria-label={copy.legalLabel}>
      <a href={copy.imprintHref}>{copy.imprint}</a>
      <a href={copy.privacyHref}>{copy.privacy}</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    padding: 1.1rem 1.5rem;
    background: var(--color-green-dark);
    color: var(--color-sand);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.25rem;
  }

  .footer p {
    margin: 0;
    white-space: nowrap;
    font-weight: 900;
    letter-spacing: 0.14em;
  }

  .footer nav {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    white-space: nowrap;
  }

  .footer a {
    color: inherit;
    text-decoration: none;
  }

  .footer a:hover {
    color: var(--color-orange);
  }

  @media (max-width: 640px) {
    .footer__inner {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "brand nav"
        "logo logo";
      gap: 0.8rem 1rem;
    }

    .footer p {
      grid-area: brand;
      font-size: 0.82rem;
      letter-spacing: 0.1em;
    }

    .footer nav {
      grid-area: nav;
      gap: 0.7rem;
      font-size: 0.82rem;
    }

    .footer :global(.rotating-logo) {
      grid-area: logo;
      justify-self: center;
    }
  }
</style>