---
interface Props {
  lang?: 'de' | 'it';
}

const { lang = 'de' } = Astro.props;

const isItalian = lang === 'it';

const copy = isItalian
  ? {
      legalLabel: 'Informazioni legali',
      imprint: 'Note legali',
      privacy: 'Privacy',
      imprintHref: '/it/impressum',
      privacyHref: '/it/datenschutz',
    }
  : {
      legalLabel: 'Rechtliches',
      imprint: 'Impressum',
      privacy: 'Datenschutz',
      imprintHref: '/impressum',
      privacyHref: '/datenschutz',
    };
---

<footer class="footer">
  <div class="container footer__inner">
    <p>SOTTO IL SOLE</p>
    <nav aria-label={copy.legalLabel}>
      <a href={copy.imprintHref}>{copy.imprint}</a>
      <a href={copy.privacyHref}>{copy.privacy}</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    padding: 2rem 1.5rem;
    background: var(--color-green-dark);
    color: var(--color-sand);
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer p {
    margin: 0;
    font-weight: 900;
    letter-spacing: 0.14em;
  }

  .footer nav {
    display: flex;
    gap: 1rem;
  }

  .footer a {
    color: inherit;
    text-decoration: none;
  }

  .footer a:hover {
    color: var(--color-orange);
  }

  @media (max-width: 640px) {
    .footer__inner {
      flex-direction: column;
    }
  }
</style>
