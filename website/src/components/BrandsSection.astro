---
import { urlFor } from '../lib/sanityImage';

interface SanityImage {
  asset?: {
    _ref?: string;
    _type?: string;
  };
}

interface Brand {
  name: string;
  slug: {
    current: string;
  };
  region?: string;
  shortDescription?: string;
  heroImage?: SanityImage;
}

interface Props {
  brands: Brand[];
  lang?: 'de' | 'it';
}

const { brands, lang = 'de' } = Astro.props;

const isItalian = lang === 'it';

const copy = isItalian
  ? {
      eyebrow: 'I nostri marchi',
      title: 'Il commercio nasce dalla fiducia.',
      intro:
        'Collaboriamo con produttori italiani selezionati, che conosciamo personalmente: piccole realt&agrave; familiari con una propria storia, radici regionali e un chiaro impegno per la qualit&agrave;.',
      button: 'Scopri i prodotti',
      detailBase: '/it/marchi',
    }
  : {
      eyebrow: 'Unsere Marken',
      title: 'Handel beginnt mit Vertrauen.',
      intro:
        'Wir arbeiten mit ausgewählten italienischen Herstellern zusammen, die wir persönlich kennen: kleine Familienbetriebe mit eigener Geschichte, regionaler Verwurzelung und einem klaren Anspruch an Qualität.',
      button: 'Produkte ansehen',
      detailBase: '/marken',
    };
---

<section class="section brands" id="marken">
  <div class="container">
    <p class="section__eyebrow">{copy.eyebrow}</p>
    <h2 class="section__title">{copy.title}</h2>
    <p class="section__intro">
      {copy.intro}
    </p>

    <div class="brands__grid">
      {brands.map((brand) => (
        <article class="brand-card">
          <div class="brand-card__media">
            {brand.heroImage && (
              <img
                class="brand-card__image"
                src={urlFor(brand.heroImage).width(1000).height(650).fit('crop').url()}
                alt={brand.name}
                loading="lazy"
              />
            )}
          </div>

          <div class="brand-card__top">
            {brand.region && <p class="brand-card__region">{brand.region}</p>}
            <h3>{brand.name}</h3>
            {brand.shortDescription && <p>{brand.shortDescription}</p>}
          </div>

          <div class="brand-card__action">
            <a href={`${copy.detailBase}/${brand.slug.current}`}>{copy.button}</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .brands {
    background: var(--color-green-dark);
    color: var(--color-sand);
  }

  .brands .section__eyebrow {
    color: rgba(222, 218, 213, 0.72);
  }

  .brands__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 3rem;
  }

  .brand-card {
    min-height: 420px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(222, 218, 213, 0.2);
    border-radius: 28px;
    background: rgba(222, 218, 213, 0.06);
  }

  .brand-card__media {
    width: 100%;
    aspect-ratio: 16 / 10;
    background: rgba(222, 218, 213, 0.12);
    overflow: hidden;
    flex-shrink: 0;
  }

  .brand-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .brand-card__top {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 1.45rem 1.35rem 0;
  }

  .brand-card__region {
    display: inline-flex;
    width: fit-content;
    margin: 0 0 1.1rem;
    border-radius: 999px;
    padding: 0.4rem 0.7rem;
    background: var(--color-orange);
    color: white;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .brand-card h3 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .brand-card p {
    line-height: 1.6;
  }

  .brand-card__top > p:not(.brand-card__region) {
    margin-top: 1rem;
    margin-bottom: 0;
    color: rgba(222, 218, 213, 0.82);
  }

  .brand-card__action {
    margin: 1.25rem 1.35rem 1.35rem;
    border-top: 1px solid rgba(222, 218, 213, 0.14);
    padding-top: 1rem;
  }

  .brand-card__action a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.6rem 0.85rem;
    background: #4b7c34;
    color: white;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: transform 180ms ease;
  }

  .brand-card__action a:hover {
    transform: translateY(-2px);
  }

  @media (max-width: 820px) {
    .brands__grid {
      grid-template-columns: 1fr;
    }
  }
</style>