---
interface Props {
  lang?: 'de' | 'it';
}

const { lang = 'de' } = Astro.props;

const isItalian = lang === 'it';

const copy = isItalian
  ? {
      eyebrow: 'Contatto',
      title: 'Interessato al nostro assortimento?',
      intro:
        'Siamo felici di ricevere richieste da grossisti, gastronomie, ristorazione e concept store.',
      botLabel: 'Non compilare:',
      name: 'Nome',
      company: 'Azienda',
      email: 'E-mail',
      message: 'Messaggio',
      privacyPrefix: 'Informazioni sul trattamento dei dati sono disponibili nella nostra',
      privacyLink: 'informativa sulla privacy',
      submit: 'Invia richiesta',
      action: '/it/grazie',
    }
  : {
      eyebrow: 'Kontakt',
      title: 'Interesse am Sortiment?',
      intro:
        'Wir freuen uns über Anfragen von Großhändlern, Feinkostgeschäften, Gastronomie und Concept Stores.',
      botLabel: 'Bitte nicht ausfüllen:',
      name: 'Name',
      company: 'Unternehmen',
      email: 'E-Mail',
      message: 'Nachricht',
      privacyPrefix: 'Informationen zur Verarbeitung Ihrer Daten finden Sie in unserer',
      privacyLink: 'Datenschutzerklärung',
      submit: 'Anfrage senden',
      action: '/danke',
    };
---

<section class="section contact" id="kontakt">
  <div class="container contact__grid">
    <div>
      <p class="section__eyebrow">{copy.eyebrow}</p>
      <h2 class="section__title">{copy.title}</h2>
      <p class="section__intro">
        {copy.intro}
      </p>
    </div>

    <form
      class="contact__form"
      name="haendleranfrage"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action={copy.action}
    >
      <input type="hidden" name="form-name" value="haendleranfrage" />

      <p class="hidden">
        <label>
          {copy.botLabel}
          <input name="bot-field" />
        </label>
      </p>

      <label>
        {copy.name}
        <input type="text" name="name" required />
      </label>

      <label>
        {copy.company}
        <input type="text" name="unternehmen" />
      </label>

      <label>
        {copy.email}
        <input type="email" name="email" required />
      </label>

      <label>
        {copy.message}
        <textarea name="nachricht" rows="5" required></textarea>
      </label>

      <p class="contact-form__privacy">
        {copy.privacyPrefix}
        <a href={isItalian ? '/it/datenschutz' : '/datenschutz'}>{copy.privacyLink}</a>.
      </p>

      <button class="button button--primary" type="submit">{copy.submit}</button>
    </form>
  </div>
</section>

<style>
  .contact {
    background: var(--color-white);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: clamp(2rem, 6vw, 5rem);
  }

  .contact__form {
    display: grid;
    gap: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 28px;
    padding: 1.35rem;
    background: var(--color-sand);
  }

  label {
    display: grid;
    gap: 0.45rem;
    font-size: 0.85rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  input,
  textarea {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 0.85rem 1rem;
    font: inherit;
    color: var(--color-green-dark);
    background: rgba(255, 250, 243, 0.7);
  }

  textarea {
    resize: vertical;
  }

  button {
  border: 0;
  cursor: pointer;
}

.contact__form .button {
  width: 100%;
  border-radius: 999px;
  padding: 0.85rem 1.15rem;
  font-size: 0.9rem;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

  .hidden {
    display: none;
  }

  .contact-form__privacy {
    margin: 0.25rem 0 0;
    color: rgba(0, 53, 20, 0.72);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .contact-form__privacy a {
    color: var(--color-green-dark);
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .contact-form__privacy a:hover {
    color: var(--color-orange);
  }

  @media (max-width: 820px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
