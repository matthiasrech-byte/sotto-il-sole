---
interface Props {
  lang?: 'de' | 'it';
}

const { lang = 'de' } = Astro.props;

const isItalian = lang === 'it';

const copy = isItalian
  ? {
      title: 'Scaricate il nostro catalogo prodotti.',
      button: 'Catalogo prodotti in PDF',
      fileName: 'catalogo-prodotti-sotto-il-sole.pdf',
    }
  : {
      title: 'Laden Sie unseren Produktkatalog herunter.',
      button: 'Produktkatalog als PDF',
      fileName: 'produktkatalog-sotto-il-sole.pdf',
    };
---

<section class="section catalog-download">
  <div class="container catalog-download__inner">
    <h2 class="section__title">{copy.title}</h2>

    <a
      class="button button--primary catalog-download__button"
      href="/produktkatalog.pdf"
      download={copy.fileName}
    >
      {copy.button}
    </a>
  </div>
</section>

<style>
  .catalog-download {
    background: var(--color-sand);
    color: var(--color-green-dark);
    padding-bottom: 0.5rem;
  }

  .catalog-download__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 4rem);
    border: 1px solid rgba(0, 53, 20, 0.14);
    border-radius: 28px;
    padding: clamp(1.5rem, 4vw, 2.4rem);
    background: rgba(255, 250, 243, 0.58);
  }

  .catalog-download .section__title {
    max-width: 820px;
    margin: 0;
  }

  .catalog-download__button {
    white-space: nowrap;
  }

  @media (max-width: 820px) {
    .catalog-download__inner {
      grid-template-columns: 1fr;
    }

    .catalog-download__button {
      width: fit-content;
    }
  }
</style>