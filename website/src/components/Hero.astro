---
interface SiteSettings {
  companyName?: string;
  heroTitle?: string;
  heroText?: string;
}

interface Props {
  siteSettings?: SiteSettings;
}

const { siteSettings } = Astro.props;

const companyName = siteSettings?.companyName || 'SOTTO IL SOLE';
const heroTitle =
  siteSettings?.heroTitle || 'Feinkost aus Italien.\nFür Tage, die nach Süden schmecken.';
const heroText =
  siteSettings?.heroText ||
  'SOTTO IL SOLE bringt ausgewählte italienische Spezialitäten nach Berlin – mit feinem Gespür für Qualität und einer guten Portion Amore.';
---

<section class="hero" id="top">
  <div class="hero__content">

    <p class="hero__eyebrow">{companyName}</p>

    <h1>{heroTitle}</h1>

    <p class="hero__intro">{heroText}</p>

    <div class="hero__actions">
      <a href="#marken" class="button button--primary">Unsere Marken entdecken</a>
      <a href="#kontakt" class="button button--secondary">Händlerkontakt aufnehmen</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 88vh;
    display: flex;
    align-items: center;
    padding: 8rem 1.5rem 5rem;
    background: var(--color-sand);
    color: var(--color-green-dark);
  }

  .hero__content {
    width: min(100%, 1120px);
    margin: 0 auto;
  }

  .hero__eyebrow {
    margin-bottom: 1.25rem;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-green-light);
    font-weight: 700;
  }

  .hero h1 {
    max-width: 920px;
    margin: 0;
    white-space: pre-line;
    font-family: var(--font-serif);
    font-size: clamp(3rem, 6.5vw, 6.2rem);
    line-height: 1.08;
    letter-spacing: -0.06em;
  }

  .hero__intro {
    max-width: 720px;
    margin-top: 2rem;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    line-height: 1.6;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.95rem 1.4rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 180ms ease, background 180ms ease, color 180ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button--primary {
    background: var(--color-orange);
    color: white;
  }

  .button--secondary {
    border: 1px solid var(--color-green-dark);
    color: var(--color-green-dark);
  }

  @media (min-width: 721px) and (max-width: 1100px) {
    .hero {
      min-height: auto;
      padding-top: 7rem;
      padding-bottom: 4rem;
    }

    .hero h1 {
      max-width: 820px;
      font-size: clamp(3.6rem, 8vw, 5.8rem);
      line-height: 1.1;
    }

    .hero__intro {
      max-width: 620px;
      margin-top: 1.6rem;
    }
  }

  @media (max-width: 720px) {
    .hero {
      padding-top: 7rem;
    }

    .hero h1 {
      line-height: 1.12;
    }
  }
</style>