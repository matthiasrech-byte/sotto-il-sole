---
interface SiteSettings {
  companyName?: string;
  heroTitle?: string;
  heroText?: string;
}

interface Props {
  siteSettings?: SiteSettings;
  lang?: 'de' | 'it';
}

const { siteSettings, lang = 'de' } = Astro.props;

const isItalian = lang === 'it';

const companyName = siteSettings?.companyName || 'SOTTO IL SOLE';

const heroTitle =
  siteSettings?.heroTitle ||
  (isItalian
    ? 'Specialit&agrave; italiane.\nPer giorni che sanno di Sud.'
    : 'Feinkost aus Italien.\nFür Tage, die nach Süden schmecken.');

const heroText =
  siteSettings?.heroText ||
  (isItalian
    ? 'SOTTO IL SOLE porta a Berlino specialit&agrave; italiane selezionate – con attenzione alla qualit&agrave; e una buona dose di amore.'
    : 'SOTTO IL SOLE bringt ausgewählte italienische Spezialitäten nach Berlin – mit feinem Gespür für Qualität und einer guten Portion Amore.');

const copy = isItalian
  ? {
      brandsButton: 'Scopri i nostri marchi',
      contactButton: 'Contattaci',
    }
  : {
      brandsButton: 'Unsere Marken entdecken',
      contactButton: 'Händlerkontakt aufnehmen',
    };
---

<section class="hero" id="top">
  <div class="hero__content">
    <p class="hero__eyebrow">{companyName}</p>

    <h1>{heroTitle}</h1>

    <p class="hero__intro">{heroText}</p>

    <div class="hero__actions">
  <a href="#kontakt" class="button button--primary">{copy.contactButton}</a>
</div>
  </div>
</section>

<style>
  .hero {
    min-height: 88vh;
    display: flex;
    align-items: center;
    padding: 8rem 1.5rem 5rem;
    background: var(--color-sand);
    color: var(--color-green-dark);
  }

  .hero__content {
    width: min(100%, 1120px);
    margin: 0 auto;
  }

  .hero__eyebrow {
    margin-bottom: 1.25rem;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-green-light);
    font-weight: 700;
  }

  .hero h1 {
    max-width: 820px;
    margin: 0;
    white-space: pre-line;
    font-family: var(--font-serif);
    font-size: clamp(3rem, 6.5vw, 6.2rem);
    line-height: 1.08;
    letter-spacing: -0.06em;
  }

  .hero__intro {
    max-width: 720px;
    margin-top: 2rem;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    line-height: 1.6;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

 .button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  padding: 0.65rem 0.7rem;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  transition: transform 180ms ease, background 180ms ease, color 180ms ease;
}

  .button:hover {
    transform: translateY(-2px);
  }

  .button--primary {
  background: #4b7c34;
  color: white;
}

  @media (min-width: 721px) and (max-width: 1100px) {
    .hero {
      min-height: auto;
      padding-top: 7rem;
      padding-bottom: 4rem;
    }

    .hero h1 {
      max-width: 760px;
      font-size: clamp(3.2rem, 6vw, 4.8rem);
      line-height: 1.1;
    }

    .hero__intro {
      max-width: 620px;
      margin-top: 1.6rem;
    }
  }

  @media (max-width: 720px) {
    .hero {
      padding-top: 7rem;
    }

    .hero h1 {
      line-height: 1.12;
    }
  }
</style>