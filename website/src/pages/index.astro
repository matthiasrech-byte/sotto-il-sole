---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import BrandsSection from '../components/BrandsSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import { sanityClient, hasSanityConfig } from '../lib/sanity';
import { brandsWithProductsQuery, aboutPageQuery, siteSettingsQuery } from '../lib/queries';
import { brands as placeholderBrands, about as placeholderAbout } from '../data/placeholder';
import CatalogDownload from '../components/CatalogDownload.astro';

let brands = placeholderBrands;
let about = placeholderAbout;
let siteSettings = null;

if (hasSanityConfig) {
  try {
    const [cmsBrands, cmsAbout, cmsSiteSettings] = await Promise.all([
  sanityClient.fetch(brandsWithProductsQuery),
  sanityClient.fetch(aboutPageQuery),
  sanityClient.fetch(siteSettingsQuery),
]);

    if (cmsBrands?.length) brands = cmsBrands;
    if (cmsAbout) about = { ...placeholderAbout, ...cmsAbout };	
    if (cmsSiteSettings) siteSettings = cmsSiteSettings;
  } catch (error) {
    console.warn('Sanity konnte nicht geladen werden. Platzhalterdaten werden verwendet.', error);
  }
}
---

<BaseLayout title="SOTTO IL SOLE | Italienische Feinkost für Händler">
  <Header />
  <main>
    <form
      name="haendleranfrage"
      method="POST"
      data-netlify="true"
      data-netlify-honeypot="bot-field"
      hidden
    >
      <input type="hidden" name="form-name" value="haendleranfrage" />
      <input type="text" name="name" />
      <input type="text" name="unternehmen" />
      <input type="email" name="email" />
      <textarea name="nachricht"></textarea>
      <input type="text" name="bot-field" />
    </form>

    <Hero siteSettings={siteSettings} />
    <BrandsSection brands={brands} />
    <CatalogDownload />
    <AboutSection about={about} />
    <ContactSection />
  </main>
  <Footer />
</BaseLayout>
