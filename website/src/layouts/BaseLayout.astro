---
import '../styles/global.css';
const { title = 'SOTTO IL SOLE', description = 'Italienische Feinkost fuer Haendler, Feinkostgeschaefte, Gastronomie und Concept Stores.' } = Astro.props;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
